# Copy to .env and fill in before `docker compose up`.

POSTGRES_USER=gridstage
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gridstage

# api
DATABASE_URL=postgres://gridstage:change-me@postgres:5432/gridstage
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:8080

# OAuth (create apps at Google Cloud Console / GitHub Developer Settings)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=gridstage
MINIO_ROOT_PASSWORD=change-me
S3_ENDPOINT=http://minio:9000
S3_BUCKET=gridstage-media
